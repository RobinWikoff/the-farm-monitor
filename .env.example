# Required for live weather fetches (or provide in .streamlit/secrets.toml)
VISUAL_CROSSING_API_KEY=your_key_here

# Runtime profile
# ENV values: dev | prod
ENV=dev

# Dev API safety switches
DEV_ALLOW_LIVE_API=false
DEV_USE_SAMPLE_DATA=true

# CI-only explicit live test opt-in
RUN_LIVE_INTEGRATION_TESTS=false

# Optional dev guardrail tuning
# DEV_GUARDRAIL_NEAR_LIMIT_PCT=0.2
# DEV_BUDGET_VC_FORECAST=24
# DEV_BUDGET_VC_HISTORICAL=12
# DEV_BUDGET_OPEN_METEO_WIND=48
# DEV_API_COOLDOWN_MINUTES=30

# Optional local cache retention (days)
# DEV_HIST_CACHE_RETENTION_DAYS=14
